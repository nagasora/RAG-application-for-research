OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
LOCAL_EMBEDDING_MODEL=local-hash-v1
RAG_REQUEST_DEADLINE_SECONDS=25
AUTH_MODE=dev
DEV_AUTH_USER=local-developer
DEV_AUTH_TOKEN=replace-with-a-long-random-local-secret
# OIDC_ISSUER=https://identity.example.com/
# OIDC_AUDIENCE=paperpilot-api
# OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
# OIDC_ALLOW_INSECURE_HTTP=false
# OIDC_ALGORITHMS=RS256
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://paperpilot:paperpilot@127.0.0.1:5432/paperpilot
MAX_UPLOAD_FILES=10
MAX_UPLOAD_BYTES=26214400
MAX_PDF_PAGES=300
PAPER_STORAGE_DIR=./data/originals
PAPER_ORIGINAL_STORAGE_DIR=./data/originals
PAPER_ASSET_STORAGE_DIR=./data/assets
SEARCH_HISTORY_STORE_ANSWER=false
INGESTION_MODE=inline
INGESTION_MAX_PAGES=300
INGESTION_MAX_SECONDS=300
INGESTION_MAX_CPU_SECONDS=240
INGESTION_MAX_INPUT_BYTES=26214400
INGESTION_MAX_ASSETS=100
INGESTION_MAX_ASSET_BYTES=20971520
INGESTION_MAX_ATTEMPTS=3
INGESTION_LEASE_SECONDS=300
INGESTION_HEARTBEAT_SECONDS=60
INGESTION_REAPER_INTERVAL_SECONDS=60
ENABLE_OCR=false
OCR_LANGUAGES=jpn+eng
OCR_DENSITY_THRESHOLD=100
OCR_TIMEOUT_SECONDS=20
OCR_FAILURE_POLICY=native
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=330
EMBEDDING_TASK_QUEUE=embedding
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_ATTEMPTS=3
EMBEDDING_LEASE_SECONDS=300
EMBEDDING_TIMEOUT_SECONDS=15
EMBEDDING_TASK_SOFT_TIME_LIMIT=180
EMBEDDING_TASK_TIME_LIMIT=210
EMBEDDING_DISPATCH_INTERVAL_SECONDS=10
EMBEDDING_DISPATCH_BATCH_SIZE=100
