NEXT_PUBLIC_API_URL=http://localhost:8000

# Required. Use dev only for local development; use oidc in deployed environments.
NEXT_PUBLIC_AUTH_MODE=dev

# Required when NEXT_PUBLIC_AUTH_MODE=dev. Sent as X-Dev-User on every API request.
NEXT_PUBLIC_DEV_USER=paperpilot-local-user

# Required in deployed OIDC mode. These are public Auth0 SPA settings, not secrets.
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-auth0-spa-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=https://your-paperpilot-api.example.com
